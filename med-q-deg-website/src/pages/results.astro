---
import Layout from '@layouts/Layout.astro';
import { SITE_CONFIG } from '@data/config';
import PerformanceChart from '@components/visualization/PerformanceChart';
import ConfusionMatrix from '@components/visualization/ConfusionMatrix';
import TSNEVisualization from '@components/visualization/TSNEVisualization';

const title = `Results - ${SITE_CONFIG.title}`;
const description = 'Benchmark results and performance analysis of degradation recognition methods.';
---

<Layout title={title} description={description}>
  <!-- Hero Section -->
  <section class="pt-32 pb-16 bg-gradient-to-b from-surface-950 via-surface-900 to-surface-950">
    <div class="container-custom">
      <div class="text-center max-w-3xl mx-auto animate-on-scroll">
        <h1 class="text-4xl sm:text-5xl font-bold mb-6">
          Benchmark <span class="gradient-text">Results</span>
        </h1>
        <p class="text-xl text-surface-400">
          Comprehensive performance analysis and visualization of degradation recognition methods.
        </p>
      </div>
    </div>
  </section>

  <!-- Tabs Navigation -->
  <section class="section">
    <div class="container-custom">
      <div class="glass-strong rounded-2xl p-2 inline-flex gap-2 mb-12 animate-on-scroll">
        <button
          class="result-tab active"
          data-tab="overview"
        >
          Overview
        </button>
        <button
          class="result-tab"
          data-tab="performance"
        >
          Performance
        </button>
        <button
          class="result-tab"
          data-tab="confusion"
        >
          Confusion Matrix
        </button>
        <button
          class="result-tab"
          data-tab="tsne"
        >
          t-SNE
        </button>
      </div>

      <!-- Overview Tab -->
      <div class="tab-content active" data-content="overview">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
          <!-- Key Metrics Cards -->
          <div class="card animate-on-scroll">
            <div class="flex items-start justify-between mb-4">
              <div>
                <p class="text-surface-500 text-sm mb-1">Overall Accuracy</p>
                <p class="text-3xl font-bold text-primary-400">87.3%</p>
              </div>
              <div class="w-12 h-12 rounded-xl bg-primary-500/20 flex items-center justify-center text-primary-400">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
            </div>
            <div class="flex items-center gap-2 text-sm">
              <span class="text-green-400">↑ 12.4%</span>
              <span class="text-surface-500">vs baseline</span>
            </div>
          </div>

          <div class="card animate-on-scroll" style="animation-delay: 100ms;">
            <div class="flex items-start justify-between mb-4">
              <div>
                <p class="text-surface-500 text-sm mb-1">F1-Score</p>
                <p class="text-3xl font-bold text-accent-400">85.6%</p>
              </div>
              <div class="w-12 h-12 rounded-xl bg-accent-500/20 flex items-center justify-center text-accent-400">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                </svg>
              </div>
            </div>
            <div class="flex items-center gap-2 text-sm">
              <span class="text-green-400">↑ 10.8%</span>
              <span class="text-surface-500">vs baseline</span>
            </div>
          </div>

          <div class="card animate-on-scroll" style="animation-delay: 200ms;">
            <div class="flex items-start justify-between mb-4">
              <div>
                <p class="text-surface-500 text-sm mb-1">Unknown Detection</p>
                <p class="text-3xl font-bold text-primary-400">92.1%</p>
              </div>
              <div class="w-12 h-12 rounded-xl bg-primary-500/20 flex items-center justify-center text-primary-400">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
              </div>
            </div>
            <div class="flex items-center gap-2 text-sm">
              <span class="text-green-400">↑ 15.2%</span>
              <span class="text-surface-500">AUROC improvement</span>
            </div>
          </div>
        </div>

        <!-- Method Comparison -->
        <div class="animate-on-scroll">
          <h2 class="text-2xl font-bold mb-6">Method Comparison</h2>

          <div class="overflow-x-auto rounded-2xl glass-strong">
            <table class="w-full">
              <thead>
                <tr class="border-b border-surface-700/50">
                  <th class="text-left p-4 text-sm font-semibold">Method</th>
                  <th class="text-center p-4 text-sm font-semibold">Accuracy</th>
                  <th class="text-center p-4 text-sm font-semibold">F1-Score</th>
                  <th class="text-center p-4 text-sm font-semibold">AUROC</th>
                  <th class="text-center p-4 text-sm font-semibold">Parameters</th>
                </tr>
              </thead>
              <tbody>
                <tr class="border-b border-surface-700/30 bg-primary-500/10">
                  <td class="p-4">
                    <div class="flex items-center gap-2">
                      <div class="w-2 h-2 rounded-full bg-primary-400"></div>
                      <span class="font-medium">DPL (Ours)</span>
                    </div>
                  </td>
                  <td class="p-4 text-center font-semibold text-primary-400">87.3%</td>
                  <td class="p-4 text-center font-semibold text-primary-400">85.6%</td>
                  <td class="p-4 text-center font-semibold text-primary-400">92.1%</td>
                  <td class="p-4 text-center text-surface-400">86.2M</td>
                </tr>
                <tr class="border-b border-surface-700/30">
                  <td class="p-4 text-surface-400">CLIP</td>
                  <td class="p-4 text-center text-surface-400">74.9%</td>
                  <td class="p-4 text-center text-surface-400">74.8%</td>
                  <td class="p-4 text-center text-surface-400">76.9%</td>
                  <td class="p-4 text-center text-surface-400">151.3M</td>
                </tr>
                <tr class="border-b border-surface-700/30">
                  <td class="p-4 text-surface-400">CoOp</td>
                  <td class="p-4 text-center text-surface-400">78.2%</td>
                  <td class="p-4 text-center text-surface-400">77.6%</td>
                  <td class="p-4 text-center text-surface-400">81.3%</td>
                  <td class="p-4 text-center text-surface-400">151.4M</td>
                </tr>
                <tr class="border-b border-surface-700/30">
                  <td class="p-4 text-surface-400">CoCoOp</td>
                  <td class="p-4 text-center text-surface-400">80.1%</td>
                  <td class="p-4 text-center text-surface-400">79.3%</td>
                  <td class="p-4 text-center text-surface-400">83.7%</td>
                  <td class="p-4 text-center text-surface-400">151.5M</td>
                </tr>
                <tr>
                  <td class="p-4 text-surface-400">ResNet-50</td>
                  <td class="p-4 text-center text-surface-400">68.5%</td>
                  <td class="p-4 text-center text-surface-400">67.2%</td>
                  <td class="p-4 text-center text-surface-400">71.4%</td>
                  <td class="p-4 text-center text-surface-400">25.6M</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Performance Tab -->
      <div class="tab-content" data-content="performance">
        <div class="animate-on-scroll">
          <h2 class="text-2xl font-bold mb-6">Performance Analysis</h2>
          <div class="card">
            <PerformanceChart client:only="react" />
          </div>
        </div>

        <!-- Per-Category Performance -->
        <div class="mt-12 animate-on-scroll">
          <h3 class="text-xl font-bold mb-6">Performance by Category</h3>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {[
              { name: 'Blur', accuracy: 89.2, f1: 87.8, color: '#6366f1' },
              { name: 'Noise', accuracy: 91.5, f1: 90.1, color: '#8b5cf6' },
              { name: 'Artifact', accuracy: 84.7, f1: 83.2, color: '#ec4899' },
              { name: 'Contrast', accuracy: 86.3, f1: 84.9, color: '#f59e0b' },
              { name: 'Compression', accuracy: 88.1, f1: 86.5, color: '#10b981' },
              { name: 'Other', accuracy: 82.4, f1: 81.0, color: '#64748b' },
            ].map((cat, i) => (
              <div class="card" style={`animation-delay: ${i * 50}ms;`}>
                <div class="flex items-center gap-3 mb-4">
                  <div class="w-3 h-3 rounded-full" style={`background: ${cat.color};`}></div>
                  <h4 class="font-semibold">{cat.name}</h4>
                </div>
                <div class="space-y-3">
                  <div>
                    <div class="flex justify-between text-sm mb-1">
                      <span class="text-surface-500">Accuracy</span>
                      <span class="font-medium">{cat.accuracy}%</span>
                    </div>
                    <div class="h-2 rounded-full bg-surface-800 overflow-hidden">
                      <div
                        class="h-full rounded-full transition-all duration-500"
                        style={`width: ${cat.accuracy}%; background: ${cat.color};`}
                      ></div>
                    </div>
                  </div>
                  <div>
                    <div class="flex justify-between text-sm mb-1">
                      <span class="text-surface-500">F1-Score</span>
                      <span class="font-medium">{cat.f1}%</span>
                    </div>
                    <div class="h-2 rounded-full bg-surface-800 overflow-hidden">
                      <div
                        class="h-full rounded-full transition-all duration-500"
                        style={`width: ${cat.f1}%; background: ${cat.color};`}
                      ></div>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Confusion Matrix Tab -->
      <div class="tab-content" data-content="confusion">
        <div class="animate-on-scroll">
          <h2 class="text-2xl font-bold mb-6">Confusion Matrix</h2>
          <div class="card">
            <ConfusionMatrix client:only="react" />
          </div>
        </div>
      </div>

      <!-- t-SNE Tab -->
      <div class="tab-content" data-content="tsne">
        <div class="animate-on-scroll">
          <h2 class="text-2xl font-bold mb-6">t-SNE Visualization</h2>
          <p class="text-surface-400 mb-6">
            Feature space visualization showing the distribution of degradation types.
          </p>
          <div class="card">
            <TSNEVisualization client:only="react" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section bg-surface-900/50">
    <div class="container-custom">
      <div class="glass-strong rounded-3xl p-8 md:p-12 text-center animate-on-scroll">
        <h2 class="text-2xl sm:text-3xl font-bold mb-4">
          Reproduce These Results
        </h2>
        <p class="text-surface-400 max-w-xl mx-auto mb-8">
          Access our code, models, and datasets to reproduce all benchmark results.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={SITE_CONFIG.links.github} class="btn btn-primary">
            View Code
          </a>
          <a href={SITE_CONFIG.links.dataset} class="btn btn-secondary">
            Download Dataset
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .result-tab {
    @apply px-6 py-3 rounded-xl text-sm font-medium transition-all duration-200;
    @apply hover:bg-surface-700/50;
  }

  .result-tab.active {
    @apply bg-gradient-to-r from-primary-600 to-accent-600 text-white shadow-lg shadow-primary-500/25;
  }

  .tab-content {
    display: none;
  }

  .tab-content.active {
    display: block;
  }

  table {
    border-collapse: separate;
    border-spacing: 0;
  }
</style>

<script>
  // Tab switching
  const tabs = document.querySelectorAll('.result-tab');
  const contents = document.querySelectorAll('.tab-content');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const targetTab = tab.getAttribute('data-tab');

      // Update active tab
      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');

      // Show corresponding content
      contents.forEach((content) => {
        const contentTab = content.getAttribute('data-content');
        if (contentTab === targetTab) {
          content.classList.add('active');
        } else {
          content.classList.remove('active');
        }
      });
    });
  });
</script>
